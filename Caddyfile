{
    auto_https off
}

:80 {
    root * /srv
    encode zstd gzip
    @assets {
        path_regexp static \.(?:avif|bmp|css|gif|ico|jpe?g|js|mjs|map|png|svg|webp|woff2?|ttf)$
    }
    header @assets Cache-Control "public, max-age=31536000, immutable"
    file_server
    @notFile {
        not file
    }
    rewrite @notFile /index.html
}
